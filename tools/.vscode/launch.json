  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "discogs",
      "type": "debugpy",
      "request": "launch",
      "module": "tools",
      "justMyCode": false,
      "args": ["discogs", "postprocess"]
    },
    {
      "name": "refresh a playlist",
      "type": "debugpy",
      "request": "launch",
      "module": "tools",
      "args": ["playlist", "refresh", "PLZ6Ih9wLHQ2ErhtuH4D-6z22JlmEHi3JW"]
    },

    {
      "name": "Debug Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "-m",
        "pytest",
        "--maxfail=1",
        "--disable-warnings",
        "-v",
        "${workspaceFolder}/tests"
      ],
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "_PYTEST_RAISE": "1"
      }
    }
  ]
}
